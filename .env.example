# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL (used by server components for internal fetch calls)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Stacks / Blockchain ─────────────────────────────────────────────────────
# Hiro Platform API key — https://platform.hiro.so
HIRO_API_KEY=

# Stacks node RPC URL (defaults to Hiro mainnet)
STACKS_API_URL=https://api.hiro.so

# Stacks network: "mainnet" | "testnet"
STACKS_NETWORK=mainnet

# ─── GitHub ──────────────────────────────────────────────────────────────────
# GitHub OAuth App credentials — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Personal Access Token (for server-side API calls, read-only scope)
GITHUB_API_TOKEN=

# ─── Authentication ───────────────────────────────────────────────────────────
# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/buildr

# ─── Payments ────────────────────────────────────────────────────────────────
# Stripe secret key (for Stacks+ subscriptions)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email ────────────────────────────────────────────────────────────────────
# SMTP or transactional email provider (e.g. Resend, Sendgrid)
EMAIL_FROM=noreply@buildr.app
RESEND_API_KEY=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Optional: Vercel Analytics, PostHog, or similar
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to enable experimental features
NEXT_PUBLIC_ENABLE_LIVE_DATA=false
NEXT_PUBLIC_ENABLE_PAYMENTS=false
